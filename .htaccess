# Brennan Jenkins portfolio — Apache / MAMP technical SEO & performance
# If the site lives in a subfolder (e.g. /brennanjenkins/), set RewriteBase accordingly.

<IfModule mod_rewrite.c>
  RewriteEngine On
  # RewriteBase /brennanjenkins/

  # Canonical host + HTTPS (enable on production)
  # RewriteCond %{HTTPS} !=on
  # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
  # RewriteCond %{HTTP_HOST} !^www\.brennanjenkins\.com$ [NC]
  # RewriteRule ^ https://www.brennanjenkins.com%{REQUEST_URI} [L,R=301]

  # Remove trailing slash on non-directories
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} (.+)/$
  RewriteRule ^ %1 [L,R=301]
</IfModule>

# Use site root, or /brennanjenkins/404.html when deployed in a subfolder
ErrorDocument 404 /404.html

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType application/pdf "access plus 1 week"
</IfModule>
